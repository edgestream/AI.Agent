{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "AI.Web",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "${workspaceFolder}/node_modules/next/dist/bin/next",
        "dev"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": false,
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!${workspaceFolder}/.next/**",
        "!**/node_modules/**"
      ],
    },
    {
      "name": "AGUINewsAgent",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/samples/dotnet/AGUINewsAgent/AGUINewsAgent.csproj",
    }
  ],
  "compounds": [
    {
      "name": "Fullstack",
      "configurations": ["AI.Web", "AGUINewsAgent"],
      "stopAll": true
    }
  ],
}
